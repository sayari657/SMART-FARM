# FARM AI — Production Environment Variables
# Copy this file to .env.production and fill in every value.
# Never commit .env.production to git.

# ── App ────────────────────────────────────────────────────────────────────────
PROJECT_NAME=Smart Farm AI
VERSION=3.0.0-Enterprise

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_32_char_random_string_here
ACCESS_TOKEN_EXPIRE_MINUTES=10080    # 7 days

# ── Database ───────────────────────────────────────────────────────────────────
# Option A — PostgreSQL (recommended for production, multi-user)
DB_USER=admin
DB_PASSWORD=CHANGE_ME_strong_database_password
DB_NAME=smart_farm
# docker-compose.yml builds this automatically from the vars above:
# DATABASE_URL=postgresql+psycopg2://admin:<DB_PASSWORD>@db:5432/smart_farm

# Option B — SQLite (single-server, simpler — no PostgreSQL container needed)
# Uncomment the line below AND remove/comment the db service in docker-compose.yml
# DATABASE_URL=sqlite:////data/smart_farm.db

# ── CORS ───────────────────────────────────────────────────────────────────────
# List every origin that may call the API (comma-separated, no trailing slash)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Caddy / HTTPS ──────────────────────────────────────────────────────────────
# Required only if you uncomment the caddy service in docker-compose.yml
DOMAIN=yourdomain.com
ADMIN_EMAIL=you@yourdomain.com

# ── OTP: Gmail SMTP ────────────────────────────────────────────────────────────
# Enable 2FA on Gmail → Security → App passwords → generate one for "Mail"
SMTP_EMAIL=your_gmail@gmail.com
SMTP_PASSWORD=your_gmail_app_password_16_chars
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465

# ── OTP: WhatsApp Cloud API ────────────────────────────────────────────────────
# developers.facebook.com → Your App → WhatsApp → API Setup
WHATSAPP_TOKEN=your_meta_whatsapp_temporary_or_permanent_token
WHATSAPP_PHONE_ID=your_whatsapp_phone_number_id

# ── Groq (cloud AI — replaces Ollama when YOLO/Ollama are not available) ───────
# console.groq.com → API Keys → Create
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Optional external APIs ─────────────────────────────────────────────────────
TREFLE_API_TOKEN=your_trefle_token_here
WEATHER_API_URL=https://api.open-meteo.com/v1/forecast
