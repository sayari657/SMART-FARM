# Smart Farm AI — Environment Configuration
# Copy this file to .env and fill in values before running

# ---- Application ----
PROJECT_NAME=Smart Farm AI
VERSION=2.0.0
API_V1_STR=/api/v1

# ---- JWT Security ----
SECRET_KEY=change_this_to_a_random_32_char_string_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ---- Database ----
# Format: postgresql+pg8000://user:password@host:port/dbname
DATABASE_URL=postgresql+pg8000://admin:password@localhost:5432/smart_farm

# ---- MQTT Broker ----
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC_PREFIX=smart_farm

# ---- Redis (optional cache/pub-sub) ----
REDIS_URL=redis://localhost:6379/0

# ---- CORS (comma-separated origins) ----
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Docker overrides (used in docker-compose.yml) ----
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=smart_farm
