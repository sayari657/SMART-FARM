# ── Smart Farm AI — Environment Template ──────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/smartfarm
USE_SQLITE=false

# Security
SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32

# AI / LLM
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_KEY

# Notifications
WHATSAPP_TOKEN=REPLACE_WITH_YOUR_META_TOKEN
WHATSAPP_PHONE_ID=REPLACE_WITH_YOUR_PHONE_ID
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=REPLACE_WITH_APP_PASSWORD

# YOLO Model Paths (defaults resolve from ai_assets/)
# YOLO_BEE_PATH=/custom/path/to/bee/best.pt
# YOLO_FIRE_PATH=/custom/path/to/fire/best.pt

# MLflow
MLFLOW_TRACKING_URI=sqlite:///mlflow.db

# Cloud Storage (for DVC remote)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_ENDPOINT_URL=

# Feature flags
LITE_MODE=false
DEBUG=false
